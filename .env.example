# Строка подключения к базе данных PostgreSQL.
# Локально — ваша локальная база. На проде — строку подключения выдаёт
# управляемая база данных хостинга (см. DEPLOY.md, шаг про базу данных).
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Общий пароль для входа всех пользователей в сервис.
# На проде задайте свой настоящий пароль — его вы сообщите лидерам.
APP_PASSWORD="change-me"

# Секретный ключ для подписи сессии (cookie). Это НЕ пароль для входа —
# его никто не вводит, он нужен серверу, чтобы подписывать вход.
# Сгенерируйте длинную случайную строку, например командой:
#   openssl rand -base64 32
# или возьмите любой генератор случайных паролей на 40+ символов.
SESSION_SECRET="change-me-to-a-long-random-string"
