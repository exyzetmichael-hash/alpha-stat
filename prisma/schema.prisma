// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Filial {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sezony Sezon[]

  @@map("filials")
}

model Sezon {
  id        String    @id @default(cuid())
  filialId  String
  filial    Filial    @relation(fields: [filialId], references: [id])
  name      String
  theme     String?
  startDate DateTime
  endDate   DateTime

  // Свободные поля сезона (раздел 3 ТЗ)
  photoUrl        String?
  thoughtsNote    String? // "Важные мысли/идеи/впечатления от сезона"
  nextSeasonNote  String? // "О чём подумать к следующему сезону"

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  stoliki      Stolik[]
  uchastniki   Uchastnik[]
  vehi         Veha[]
  budjetZapisi BudjetZapis[]
  reklama      Reklama[]
  vypuskniki   Vypusknik[]
  zametki      Zametka[]

  @@map("sezony")
}

model Stolik {
  id        String    @id @default(cuid())
  sezonId   String
  sezon     Sezon     @relation(fields: [sezonId], references: [id])
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  uchastniki Uchastnik[]

  @@map("stoliki")
}

// Глобальный справочник ролей (раздел 3.2 ТЗ) — редактируется без правки кода:
// при выборе "другое" и вводе нового значения роль автоматически добавляется
// в этот список и дальше предлагается всем в выпадающем списке.
model Rol {
  id         String    @id @default(cuid())
  name       String    @unique
  // Стандартные роли (из seed.ts) защищены от удаления; роли, добавленные
  // лидером через "Другое...", можно удалить.
  isStandard Boolean   @default(false)
  // Где роль предлагается: за столиком (STOLIK) или в команде вне столиков
  // (KOMANDA). Списки ролей в этих двух контекстах разные.
  scope      RolScope  @default(KOMANDA)
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?

  @@map("roli")
}

enum RolScope {
  STOLIK
  KOMANDA
}

model Uchastnik {
  id       String  @id @default(cuid())
  sezonId  String
  sezon    Sezon   @relation(fields: [sezonId], references: [id])
  stolikId String?
  stolik   Stolik? @relation(fields: [stolikId], references: [id])

  name     String
  roleName String
  note     String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("uchastniki")
}

// Важные вехи / события сезона (раздел 3.3 ТЗ)
model Veha {
  id      String @id @default(cuid())
  sezonId String
  sezon   Sezon  @relation(fields: [sezonId], references: [id])

  name              String
  date              DateTime
  participantCount  Int?
  note              String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("vehi")
}

enum BudjetTip {
  RASHOD
  DOHOD
}

// Глобальный справочник категорий бюджета (раздел 3.6 ТЗ) — общий для всех сезонов,
// чтобы итоги по категориям были консистентны между сезонами на дашборде.
model BudjetKategoriya {
  id        String    @id @default(cuid())
  tip       BudjetTip
  name      String
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@unique([tip, name])
  @@map("budjet_kategorii")
}

// Статья бюджета (расход или доход) в рамках сезона (раздел 3.6 ТЗ)
model BudjetZapis {
  id      String @id @default(cuid())
  sezonId String
  sezon   Sezon  @relation(fields: [sezonId], references: [id])

  tip          BudjetTip
  categoryName String
  amount       Int
  comment      String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("budjet_zapisi")
}

// Запись рекламной кампании сезона (раздел 3.4 ТЗ)
model Reklama {
  id      String @id @default(cuid())
  sezonId String
  sezon   Sezon  @relation(fields: [sezonId], references: [id])

  date              DateTime
  action            String // "что делали"
  materialsNote     String? // остались ли материалы (текст/ссылка)
  effectivenessNote String? // оценка эффективности (текст)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("reklama")
}

// Выпускник сезона (раздел 3.5 ТЗ)
model Vypusknik {
  id      String @id @default(cuid())
  sezonId String
  sezon   Sezon  @relation(fields: [sezonId], references: [id])

  name             String
  statusRightAfter String[] // "сразу после Альфы" (можно несколько статусов)
  statusSixMonths  String[] // "через полгода" (можно несколько статусов)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("vypuskniki")
}

// Идеи и заметки по событиям сезона (раздел 3.7 ТЗ)
model Zametka {
  id      String @id @default(cuid())
  sezonId String
  sezon   Sezon  @relation(fields: [sezonId], references: [id])

  details String? // "Подробности события"
  idea    String? // "Идея сценария и фишки"

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("zametki")
}
